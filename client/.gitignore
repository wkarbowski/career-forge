# ====================================================
# Career Forge Client .gitignore
# ====================================================

# Node dependencies
/node_modules
/.pnp
.pnp.js

# Testing
/coverage

# Production build
/build

# Public folder: keep folder structure but ignore content
public/uploads/*
!public/uploads/.gitkeep

# Environment
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDEs / Editors
.idea
.vscode
*.swp
*.swo
*~

# Caches
.cache/
.parcel-cache/

# OS files
.DS_Store
