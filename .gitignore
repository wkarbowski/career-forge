# Node dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output
build/
dist/

# Environment variables
.env
.env.cloud
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
logs/
*.log
pids/
*.pid
*.seed
*.pid.lock

# Editor directories and files
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# OS files
.DS_Store
Thumbs.db

# Optional npm cache
.npm/
.cache/

# Testing
coverage/
*.lcov
.pytest_cache/
.coverage

# Misc
*.tgz
*.bak
*.tmp

# JetBrains IDE
out/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
venv/
.venv/
*.egg-info/
.eggs/

# Server specific
server/.env
server/.env.production
server/.env.local
server/*.log

# Databases — never commit data files
*.sqlite3
*.db
*.db.gz
*.db-wal
*.db-shm

# Production database backups — never commit data files
server/backups/*
!server/backups/.gitkeep
server/uploads/*
!server/uploads/.gitkeep
!server/uploads/profile_images/.gitkeep
client/build/

# NOTE: server/app/cloud/ and client/src/cloud/ stub directories ARE tracked
# in this repo — they define the extension interface contract.
# Extension modules replace their content at deploy time.
