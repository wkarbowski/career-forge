# ─────────────────────────────────────────────────────────────────────────────
# Career Forge — root .env.example (docker-compose)
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Never commit your real .env to version control.
# The .env file is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=careerforge
POSTGRES_USER=careerforge
# Generate a strong password:  openssl rand -hex 24
POSTGRES_PASSWORD=<your-strong-db-password>

# ── Redis ─────────────────────────────────────────────────────────────────────
# Generate a strong password:  openssl rand -hex 24
REDIS_PASSWORD=<your-strong-redis-password>

# ── Backend ───────────────────────────────────────────────────────────────────
# Generate the secret key:  openssl rand -hex 32
SECRET_KEY=<your-64-char-secret-key>

APP_NAME=Career Forge API
# Docker Compose maps these to backend ENVIRONMENT and DEBUG.
# Project-scoped names avoid collisions with shell variables such as DEBUG.
CAREER_FORGE_ENVIRONMENT=development   # development | staging | production
CAREER_FORGE_DEBUG=true                # Set to false in production

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost

# Security (production only)
ENFORCE_HTTPS=false
COOKIE_SECURE=false   # Set to true in production (requires HTTPS)
COOKIE_SAMESITE=lax
TRUSTED_HOSTS=        # Comma-separated: yourapp.com,www.yourapp.com

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_PORT=80
VITE_API_URL=/api
VITE_GDPR=false

# ── Workers (production) ──────────────────────────────────────────────────────
GUNICORN_WORKERS=4
