# .env.devcontainer.example
# Example environment variables for devcontainer (do not use real secrets)
DATABASE_URL=postgresql://careerforge:${POSTGRES_PASSWORD}@postgres:5432/careerforge_dev
SECRET_KEY=your-dev-secret-key
POSTGRES_DB=careerforge_dev
POSTGRES_USER=careerforge
POSTGRES_PASSWORD=yourpassword
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_BACKEND=memory
VITE_API_URL=/api
