{
  "name": "career-forge",
  "version": "1.0.0",
  "description": "Self-hostable CV and resume builder — WYSIWYG editor, multi-page A4, templates, auth, Docker.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wkarbowski/career-forge.git"
  },
  "private": true,
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/josefin-sans": "^5.2.8",
    "@fontsource/lato": "^5.2.7",
    "@fontsource/lora": "^5.2.8",
    "@fontsource/merriweather": "^5.2.11",
    "@fontsource/montserrat": "^5.2.8",
    "@fontsource/nunito": "^5.2.7",
    "@fontsource/open-sans": "^5.2.7",
    "@fontsource/oswald": "^5.2.8",
    "@fontsource/playfair-display": "^5.2.8",
    "@fontsource/poppins": "^5.2.7",
    "@fontsource/pt-sans": "^5.2.8",
    "@fontsource/raleway": "^5.2.8",
    "@fontsource/roboto": "^5.2.9",
    "@fontsource/rubik": "^5.2.8",
    "@fontsource/source-sans-3": "^5.2.9",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "dompurify": "^3.4.5",
    "html2canvas": "^1.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-easy-crop": "^5.5.7",
    "react-router-dom": "^7.15.1"
  },
  "scripts": {
    "preinstall": "node scripts/require-pnpm.cjs",
    "prestart": "node scripts/require-pnpm.cjs",
    "prebuild": "node scripts/require-pnpm.cjs",
    "prelint": "node scripts/require-pnpm.cjs",
    "prepreview": "node scripts/require-pnpm.cjs",
    "pretest": "node scripts/require-pnpm.cjs",
    "pretest:watch": "node scripts/require-pnpm.cjs",
    "pretest:coverage": "node scripts/require-pnpm.cjs",
    "start": "vite",
    "build": "vite build",
    "lint": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
